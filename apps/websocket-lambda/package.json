{
  "name": "websocket-lambda",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1007.0",
    "@aws-sdk/client-dynamodb": "^3.1007.0",
    "@aws-sdk/lib-dynamodb": "^3.1007.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "apps/websocket-lambda/dist",
          "format": [
            "cjs"
          ],
          "bundle": true,
          "main": "apps/websocket-lambda/src/handler.ts",
          "tsConfig": "apps/websocket-lambda/tsconfig.app.json",
          "assets": [
            "apps/websocket-lambda/src/assets"
          ],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".js"
            }
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".js"
              }
            }
          }
        }
      },
      "deploy": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "build"
        ],
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "7z a deploy/function.zip dist/handler.js -y",
            "aws lambda update-function-code --function-name GameWebSocketHandler --zip-file fileb://deploy/function.zip",
            "aws lambda wait function-updated --function-name GameWebSocketHandler",
            "aws lambda wait function-active --function-name GameWebSocketHandler"
          ],
          "parallel": false
        }
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "websocket-lambda:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "websocket-lambda:build:development"
          },
          "production": {
            "buildTarget": "websocket-lambda:build:production"
          }
        }
      }
    }
  }
}
